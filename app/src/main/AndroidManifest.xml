<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Camera availability (optional) -->
    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />

    <!-- Permissions -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Required for Android 11+ when launching system camera -->
    <queries>
        <intent>
            <action android:name="android.media.action.IMAGE_CAPTURE" />
        </intent>
    </queries>

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/logos"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.FoodOrderingApp"
        android:windowSoftInputMode="adjustResize"
        tools:targetApi="31">

        <!-- Admin Activities -->
        <activity
            android:name=".admin.activity.ManageAdvertisementActivity"
            android:exported="false" />
        <activity
            android:name=".admin.activity.AdminEnquiryActivity"
            android:exported="false" />
        <activity
            android:name=".admin.activity.AdminSettingsActivity"
            android:exported="false" />
        <activity
            android:name=".admin.activity.OrdersActivity"
            android:exported="false" />
        <activity
            android:name=".admin.activity.ManageItemsActivity"
            android:exported="false" />
        <activity
            android:name=".admin.activity.FeedbackActivity"
            android:exported="false" />
        <activity
            android:name=".admin.activity.DeliveredOrdersActivity"
            android:exported="false" />
        <activity
            android:name=".admin.activity.OrderDetailsActivity"
            android:exported="false" />

        <!-- Firebase Messaging -->
        <service
            android:name=".admin.message.MyFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <activity
            android:name=".admin.activity.AdminMainActivity"
            android:exported="false" />

        <!-- User Activities -->
        <activity
            android:name=".user.activity.EditProfileActivity"
            android:exported="false" />
        <activity
            android:name=".user.activity.UserEnquiryActivity"
            android:exported="false" />
        <activity
            android:name=".admin.activity.AddItemActivity"
            android:exported="false" />
        <activity
            android:name=".user.activity.FeedbackActivity"
            android:exported="false" />

        <!-- Login Launcher Activity -->
        <activity
            android:name=".user.activity.LoginActivity"
            android:exported="true"
            android:theme="@style/Theme.KrishnaFoods.login">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".user.activity.MainActivity"
            android:exported="false"
            android:theme="@style/Theme.KrishnaFoods.user" />
        <activity
            android:name=".user.activity.ProfileActivity"
            android:exported="false" />
        <activity
            android:name=".user.activity.OrderSuccessActivity"
            android:exported="false" />
        <activity
            android:name=".user.activity.OrderConfirmationActivity"
            android:exported="false"
            android:theme="@style/Theme.KrishnaFoods.user" />
        <activity
            android:name=".user.activity.ProfileSetupActivity"
            android:exported="false"
            android:theme="@style/Theme.KrishnaFoods.login" />
        <activity
            android:name=".user.activity.AboutActivity"
            android:exported="false"
            android:theme="@style/Theme.KrishnaFoods.user" />

        <!-- FileProvider -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_path" />
        </provider>

        <!-- Firebase Meta Data -->
        <meta-data
            android:name="com.google.android.gms.version"
            android:value="@integer/google_play_services_version" />

    </application>

</manifest>
