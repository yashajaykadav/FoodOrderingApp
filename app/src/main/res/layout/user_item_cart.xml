<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:strokeColor="#10000000"
    app:strokeWidth="0.5dp"
    app:cardBackgroundColor="@android:color/white">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Food Image with better styling -->
        <ImageView
            android:id="@+id/foodImage"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:contentDescription="@string/iteam_image"
            android:scaleType="centerCrop"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintWidth_percent="0.25"
            android:background="@color/lightBackground"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.CornerSmall"
            tools:src="@drawable/default_img" />

        <!-- Main Details Container -->
        <LinearLayout
            android:id="@+id/detailsContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingEnd="8dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/actionButtonsContainer"
            app:layout_constraintStart_toEndOf="@id/foodImage"
            app:layout_constraintTop_toTopOf="parent">

            <!-- Name and Category -->
            <TextView
                android:id="@+id/foodName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Food Name"
                android:textColor="#FF1A1A1A"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/foodCategory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="food_category"
                android:textColor="#80000000"
                android:textSize="12sp"
                android:drawablePadding="4dp"
                android:drawableStart="@drawable/ic_category"
                android:drawableTint="#80000000" />

            <!-- Weight and Stock -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/foodWeight"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/weight"
                    android:textColor="#80000000"
                    android:textSize="12sp"
                    android:drawablePadding="4dp"
                    android:drawableStart="@drawable/ic_weight"
                    app:drawableTint="#80000000" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="12dp"
                    android:layout_marginHorizontal="8dp"
                    android:background="#20000000" />

                <TextView
                    android:id="@+id/foodStock"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/stock_badge_bg"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="1dp"
                    android:text="In Stock"
                    android:textColor="@android:color/white"
                    android:textSize="10sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.05" />
            </LinearLayout>

            <!-- Price Information -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/foodPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹120"
                    android:textColor="#FF5722"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/foodUnitPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="(₹0.48/g)"
                    android:textColor="#80000000"
                    android:textSize="10sp" />
            </LinearLayout>

            <!-- Quantity Controls -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/rounded_quantity_bg"
                android:orientation="horizontal"
                android:padding="2dp">

                <ImageButton
                    android:id="@+id/btnDecrease"
                    style="@style/QuantityButtonStyle"
                    android:src="@drawable/minus"
                    android:contentDescription="@string/decrease_quantity"
                    android:background="?attr/selectableItemBackgroundBorderless" />

                <EditText
                    android:id="@+id/quantityText"
                    android:layout_width="32dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="1"
                    android:textColor="@android:color/black"
                    android:textSize="14sp" />

                <ImageButton
                    android:id="@+id/btnIncrease"
                    style="@style/QuantityButtonStyle"
                    android:src="@drawable/add"
                    android:contentDescription="@string/increase_quantity"
                    android:background="?attr/selectableItemBackgroundBorderless" />
            </LinearLayout>
        </LinearLayout>

        <!-- Action Buttons Container -->
        <LinearLayout
            android:id="@+id/actionButtonsContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="4dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageButton
                android:id="@+id/btnRemove"
                style="@style/ActionButtonStyle"
                android:src="@drawable/ic_delete"
                android:contentDescription="@string/remove"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="#FF5252" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>