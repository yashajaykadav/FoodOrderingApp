<resources>
    <style name="Theme.KrishnaFoods" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/google_blue</item>
        <item name="colorPrimaryVariant">@color/google_blue</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <style name="Theme.KrishnaFoods.user" parent="Theme.KrishnaFoods">
        <item name="android:statusBarColor">@color/lightRed</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Theme.KrishnaFoods.admin" parent="Theme.KrishnaFoods">
        <item name="android:statusBarColor">@color/colorAccent</item>
        <item name="android:windowLightStatusBar">false</item> </style>

    <style name="Theme.KrishnaFoods.login" parent="Theme.KrishnaFoods">
        <item name="android:statusBarColor">@color/google_blue</item>
        <item name="android:windowLightStatusBar">false</item> </style>


    <style name="Widget.MyApp.Chip.Filter" parent="Widget.MaterialComponents.Chip.Filter">
        <item name="android:textColor">@color/chip_text_selected</item>
        <item name="android:minHeight">36dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:ellipsize">end</item>
        <item name="android:maxLines">1</item>
        <item name="shapeAppearance">@style/ShapeAppearance.MyApp.SmallComponent</item>
    </style>

    <style name="ShapeAppearance.MyApp.SmallComponent" parent="ShapeAppearance.MaterialComponents.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
    </style>
</resources>