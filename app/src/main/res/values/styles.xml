<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:android="http://schemas.android.com/apk/res/android">
    <style name="QuantityButtonStyle">
        <item name="android:layout_width">32dp</item>
        <item name="android:layout_height">32dp</item>
        <item name="android:scaleType">centerInside</item>
        <item name="android:tint">?attr/colorPrimary</item>
    </style>

    <style name="ActionButtonStyle">
        <item name="android:layout_width">36dp</item>
        <item name="android:layout_height">36dp</item>
        <item name="android:scaleType">centerInside</item>
    </style>

        <!-- Text Styles -->
        <style name="OrderInfoTitle">
            <item name="android:textSize">16sp</item>
            <item name="android:textStyle">bold</item>
            <item name="android:textColor">#000000</item>
            <item name="android:paddingBottom">4dp</item>
        </style>

        <style name="OrderInfoText">
            <item name="android:textSize">14sp</item>
            <item name="android:textColor">#000000</item>
            <item name="android:paddingBottom">4dp</item>
        </style>

        <style name="OrderInfoStatus">
            <item name="android:textSize">14sp</item>
            <item name="android:textStyle">bold</item>
            <item name="android:textColor">?attr/colorPrimary</item>
            <item name="android:paddingBottom">6dp</item>
        </style>

        <style name="OrderItemsBox">
            <item name="android:layout_width">match_parent</item>
            <item name="android:layout_height">wrap_content</item>
            <item name="android:textSize">14sp</item>
            <item name="android:textColor">#555555</item>
            <item name="android:padding">8dp</item>
            <item name="android:background">@android:color/darker_gray</item>
            <item name="android:layout_marginBottom">8dp</item>
        </style>

        <style name="OrderRejectionText">
            <item name="android:textSize">14sp</item>
            <item name="android:textColor">@android:color/holo_red_dark</item>
            <item name="android:padding">6dp</item>
            <item name="android:background">@android:color/white</item>
            <item name="android:elevation">2dp</item>
            <item name="android:layout_marginTop">4dp</item>
        </style>

        <!-- Button Styles -->
        <style name="OrderButton.Base" parent="Widget.MaterialComponents.Button">
            <item name="android:layout_width">wrap_content</item>
            <item name="android:layout_height">wrap_content</item>
            <item name="android:textColor">@android:color/white</item>
            <item name="android:layout_marginEnd">8dp</item>
            <item name="cornerRadius">16dp</item>
            <item name="android:elevation">4dp</item>

        </style>

        <style name="OrderButton.Red" parent="OrderButton.Base">
            <item name="backgroundTint">@android:color/holo_red_light</item>
        </style>

        <style name="OrderButton.Blue" parent="OrderButton.Base">
            <item name="backgroundTint">@android:color/holo_blue_light</item>
        </style>

    <style name="ShapeAppearanceOverlay.CornerSmall" parent="">
        <item name="cornerSize">8dp</item>
    </style>

    <style name="ShapeAppearanceOverlay.BottomSheet" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">24dp</item>
        <item name="cornerSizeTopRight">24dp</item>
    </style>
    <style name="CircleImageStyle">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>
    <style name="BottomSheetDialogRounded" parent="Theme.Design.Light.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/BottomSheetStyle</item>
    </style>

    <style name="BottomSheetStyle" parent="Widget.Design.BottomSheet.Modal">
        <item name="android:background">@android:color/transparent</item>
    </style>
    <style name="CircleImageWithBorder" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>
    <drawable name="divider_vertical_8dp">
        <shape android:shape="rectangle">
            <size android:height="8dp" />
        </shape>
    </drawable>
    <style name="ShapeNavigationDrawer" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopRight">24dp</item>
        <item name="cornerSizeBottomRight">24dp</item>
    </style>
    <style name="ShapeBottomNavBar" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">16dp</item>
        <item name="cornerSizeTopRight">16dp</item>
        <item name="android:elevation">8dp</item>
    </style>
    <style name="UserActionButton" parent="Widget.AppCompat.Button.Borderless">
        <item name="android:textColor">@color/white</item>
        <item name="android:backgroundTint">@color/colorPrimary</item>
        <item name="android:padding">8dp</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- Add these to your existing styles.xml -->
    <style name="BottomNavItemStyle" parent="Widget.MaterialComponents.BottomNavigationView.Colored">
        <item name="itemTextAppearanceActive">@style/BottomNavTextActive</item>
        <item name="itemTextAppearanceInactive">@style/BottomNavTextInactive</item>
        <item name="itemRippleColor">@color/bottom_nav_ripple</item>
        <item name="itemBackground">@drawable/bottom_nav_item_background</item>
    </style>

    <style name="BottomNavTextActive" parent="TextAppearance.AppCompat.Small">
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="BottomNavTextInactive" parent="TextAppearance.AppCompat.Small">
        <item name="android:textColor">@color/black</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="ShapeAppearanceOverlay.App.CornerSize12dp" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>
    <!-- Define a theme for the rounded dialog pop-up -->
    <style name="CustomDialogTheme" parent="Theme.AppCompat.Light.Dialog">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowCloseOnTouchOutside">true</item>
        <item name="android:windowBackground">@drawable/dialog_background_rounded</item>
        <item name="android:windowAnimationStyle">@style/DialogAnimation</item>
    </style>

    <!-- (Optional) Dialog slide animation -->
    <style name="DialogAnimation">
        <item name="android:windowEnterAnimation">@anim/dialog_slide_down</item>
        <item name="android:windowExitAnimation">@anim/dialog_slide_up</item>
    </style>

</resources>